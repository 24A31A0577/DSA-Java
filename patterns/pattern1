/*
Pattern 1 - Square Star Pattern
Input: n = 5
Output:
*****
*****
*****
*****
*****
*/

class Solution {
    public void pattern1(int n) {
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < n; j++) {
                System.out.print("*");
            }
            System.out.println();
        }
    }
}
