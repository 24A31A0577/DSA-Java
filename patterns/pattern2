/*
Pattern 2 - Right Triangle Star Pattern
Input: n = 5
Output:
*
**
***
****
*****
*/

class Solution {
    public void pattern2(int n) {
        for(int i = 0; i < n; i++) {
            for(int j = 0; j <= i; j++) {
                System.out.print("*");
            }
            System.out.println();
        }
    }
}
