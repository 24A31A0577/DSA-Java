/*
Pattern 5
Input: n = 5
Output:
*****
****
***
**
*
*/
class Solution {
    public void pattern5(int n) {
        for(int i=0;i<n;i++)
        {
            for(int j=0;j<(n-i);j++)
            {
                System.out.print("*");
            }
            System.out.println();
        }
    }
}
