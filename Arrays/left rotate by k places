/*
 * Left Rotate Array by K Positions (Using Temporary Array)
 *
 * Idea:
 * Store the first k elements in a temporary array.
 * Shift the remaining elements to the left by k positions.
 * Copy the elements from the temporary array to the end.
 *
 * Note:
 * Reduce k using k % n to avoid unnecessary rotations.
 *
 * Time Complexity:
 * Best Case: O(n)
 * Average Case: O(n)
 * Worst Case: O(n)
 *
 * Space Complexity: O(k)
 */

public class LeftRotateArray {

    public void rotate(int[] nums, int k) {
        int n = nums.length;
        k = k % n;

        int[] temp = new int[k];

        // Store first k elements
        for (int i = 0; i < k; i++) {
            temp[i] = nums[i];
        }

        // Shift remaining elements to the left
        for (int i = k; i < n; i++) {
            nums[i - k] = nums[i];
        }

        // Copy temporary array to the end
        for (int i = 0; i < k; i++) {
            nums[n - k + i] = temp[i];
        }
    }

    public static void main(String[] args) {
        int[] nums = {1, 2, 3, 4, 5, 6, 7};
        int k = 3;

        LeftRotateArray obj = new LeftRotateArray();
        obj.rotate(nums, k);

        System.out.print("Left Rotated Array: ");
        for (int num : nums) {
            System.out.print(num + " ");
        }
    }
}
