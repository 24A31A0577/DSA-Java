/*
 * Max Consecutive Ones (LeetCode 485)
 *
 * Problem:
 * Given a binary array nums, return the maximum number of
 * consecutive 1's present in the array.
 *
 * Approach:
 * 1. Traverse the array from left to right.
 * 2. Maintain a counter to keep track of consecutive 1's.
 * 3. If the current element is 1, increment the counter.
 * 4. If the current element is 0:
 *    - Update the maximum count if needed.
 *    - Reset the counter to 0.
 * 5. After the traversal, perform one final comparison
 *    because the array may end with consecutive 1's.
 *
 * Time Complexity:
 * Best Case: O(n)
 * Average Case: O(n)
 * Worst Case: O(n)
 *
 * Space Complexity:
 * O(1)
 */

public class MaxConsecutiveOnes {

    public int findMaxConsecutiveOnes(int[] nums) {

        int count = 0;
        int max = 0;

        // Traverse the array
        for (int i = 0; i < nums.length; i++) {

            if (nums[i] == 1) {
                count++;
            } else {

                // Update maximum consecutive ones
                if (max < count) {
                    max = count;
                }

                // Reset counter
                count = 0;
            }
        }

        // Handle the case where the array ends with 1's
        if (max < count) {
            max = count;
        }

        return max;
    }

    public static void main(String[] args) {

        int[] nums = {1, 1, 0, 1, 1, 1};

        MaxConsecutiveOnes obj = new MaxConsecutiveOnes();

        System.out.println("Maximum Consecutive Ones: " +
                obj.findMaxConsecutiveOnes(nums));
    }
}
