/*
 * Linear Search
 *
 * Problem:
 * Given an array of integers and a target value, return the
 * index of the target if it exists in the array.
 * If the target is not present, return -1.
 *
 * Approach:
 * 1. Traverse the array from the beginning.
 * 2. Compare each element with the target value.
 * 3. If a match is found, return its index immediately.
 * 4. If the entire array is traversed without finding the
 *    target, return -1.
 *
 * Linear Search works on both sorted and unsorted arrays.
 * It is simple to implement but is not efficient for large datasets.
 *
 * Time Complexity:
 * Best Case: O(1)
 * Average Case: O(n)
 * Worst Case: O(n)
 *
 * Space Complexity:
 * O(1)
 */

public class LinearSearch {

    public int linearSearch(int[] nums, int target) {

        // Traverse the array
        for (int i = 0; i < nums.length; i++) {

            // Target found
            if (nums[i] == target) {
                return i;
            }
        }

        // Target not found
        return -1;
    }

    public static void main(String[] args) {

        int[] nums = {12, 25, 8, 19, 30};
        int target = 19;

        LinearSearch obj = new LinearSearch();

        int index = obj.linearSearch(nums, target);

        if (index != -1) {
            System.out.println("Target found at index: " + index);
        } else {
            System.out.println("Target not found.");
        }
    }
}
