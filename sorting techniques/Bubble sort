/*
 * Bubble Sort Algorithm
 *
 * Idea:
 * Repeatedly compare adjacent elements and swap them
 * if they are in the wrong order. After each pass,
 * the largest unsorted element moves to its correct position.
 *
 * Time Complexity:
 * Worst Case: O(n^2)
 * Average Case: O(n^2)
 * Best Case: O(n) (with optimization)
 *
 * Space Complexity: O(1)
 */
public class BubbleSort {
    public int[] bubbleSort(int[] nums) {
        int n = nums.length;
        for(int i = n - 1; i > 0; i--) {
            for(int j = 0; j < i; j++) {
                if(nums[j] > nums[j + 1]) {
                    int temp = nums[j];
                    nums[j] = nums[j + 1];
                    nums[j + 1] = temp;
                }
            }
        }
        return nums;
    }
    public static void main(String[] args) {
        int[] nums = {45,24, 33, 12, 1};
        BubbleSort obj = new BubbleSort();
        obj.bubbleSort(nums);
        System.out.print("Sorted Array: ");
        for(int num : nums) {
            System.out.print(num + " ");
        }
    }
}
